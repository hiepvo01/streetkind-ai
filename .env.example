# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Firebase (optional - only needed for /api/submit)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# AI model override (optional - defaults to config/app.json value)
# AI_MODEL=claude-haiku-4-5-20251001

# Whisper model override (optional - defaults to config/app.json value)
# WHISPER_MODEL=base
